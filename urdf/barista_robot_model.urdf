<?xml version="1.0"?>
<robot name="barista_robot">

  <!-- ===================== MATERIALS (RViz colours) ===================== -->
  <material name="body_blue"><color rgba="0.10 0.35 0.75 1.0"/></material>
  <material name="tray_white"><color rgba="0.92 0.92 0.92 1.0"/></material>
  <material name="dark_grey"><color rgba="0.15 0.15 0.15 1.0"/></material>
  <material name="metal_grey"><color rgba="0.55 0.55 0.55 1.0"/></material>
  <material name="laser_black"><color rgba="0.05 0.05 0.05 1.0"/></material>

  <!-- ============================ MAIN BODY ============================ -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.178" length="0.155"/></geometry>
      <material name="body_blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.178" length="0.155"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="2.0"/>
      <!-- cylinder: Ixx=Iyy=(1/12)m(3r^2+h^2), Izz=(1/2)m r^2 -->
      <inertia ixx="0.019846" ixy="0.0" ixz="0.0"
               iyy="0.019846" iyz="0.0" izz="0.031684"/>
    </inertial>
  </link>

  <!-- ============================ DRIVE WHEELS ============================ -->
  <!-- LEFT WHEEL -->
  <link name="left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0352" length="0.0206"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0352" length="0.0206"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <mass value="0.3"/>
      <inertia ixx="0.000104" ixy="0.0" ixz="0.0"
               iyy="0.000104" iyz="0.0" izz="0.000186"/>
    </inertial>
  </link>
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <!-- y = body_radius(0.178) + wheel_half_width(0.0103) = 0.1883 -->
    <origin xyz="0 0.1883 -0.0775" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- RIGHT WHEEL -->
  <link name="right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0352" length="0.0206"/></geometry>
      <material name="dark_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.0352" length="0.0206"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <mass value="0.3"/>
      <inertia ixx="0.000104" ixy="0.0" ixz="0.0"
               iyy="0.000104" iyz="0.0" izz="0.000186"/>
    </inertial>
  </link>
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0 -0.1883 -0.0775" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ============================ CASTER WHEELS ============================ -->
  <!-- FRONT CASTER -->
  <link name="front_caster">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.025"/></geometry>
      <material name="metal_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.025"/></geometry>
      <surface><friction><ode><mu>0.0</mu><mu2>0.0</mu2></ode></friction></surface>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <!-- sphere: I=(2/5)m r^2 -->
      <inertia ixx="0.0000125" ixy="0.0" ixz="0.0"
               iyy="0.0000125" iyz="0.0" izz="0.0000125"/>
    </inertial>
  </link>
  <joint name="front_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="front_caster"/>
    <origin xyz="0.12 0 -0.0877" rpy="0 0 0"/>
  </joint>

  <!-- BACK CASTER -->
  <link name="back_caster">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.025"/></geometry>
      <material name="metal_grey"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><sphere radius="0.025"/></geometry>
      <surface><friction><ode><mu>0.0</mu><mu2>0.0</mu2></ode></friction></surface>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.05"/>
      <inertia ixx="0.0000125" ixy="0.0" ixz="0.0"
               iyy="0.0000125" iyz="0.0" izz="0.0000125"/>
    </inertial>
  </link>
  <joint name="back_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="back_caster"/>
    <origin xyz="-0.12 0 -0.0877" rpy="0 0 0"/>
  </joint>

  <!-- ============================ STANDOFF RODS (x4) ============================ -->
  <!-- rod centre z = body_top(0.0775) + rod_half(0.11) = 0.1875 -->
  <link name="standoff_rod_1">
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.010" length="0.22"/></geometry>
      <material name="metal_grey"/></visual>
    <collision><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.010" length="0.22"/></geometry></collision>
    <inertial><origin xyz="0 0 0" rpy="0 0 0"/><mass value="0.10"/>
      <inertia ixx="0.000406" ixy="0.0" ixz="0.0" iyy="0.000406" iyz="0.0" izz="0.000005"/></inertial>
  </link>
  <joint name="standoff_rod_1_joint" type="fixed">
    <parent link="base_link"/><child link="standoff_rod_1"/>
    <origin xyz="0.10 0.10 0.1875" rpy="0 0 0"/>
  </joint>

  <link name="standoff_rod_2">
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.010" length="0.22"/></geometry>
      <material name="metal_grey"/></visual>
    <collision><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.010" length="0.22"/></geometry></collision>
    <inertial><origin xyz="0 0 0" rpy="0 0 0"/><mass value="0.10"/>
      <inertia ixx="0.000406" ixy="0.0" ixz="0.0" iyy="0.000406" iyz="0.0" izz="0.000005"/></inertial>
  </link>
  <joint name="standoff_rod_2_joint" type="fixed">
    <parent link="base_link"/><child link="standoff_rod_2"/>
    <origin xyz="0.10 -0.10 0.1875" rpy="0 0 0"/>
  </joint>

  <link name="standoff_rod_3">
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.010" length="0.22"/></geometry>
      <material name="metal_grey"/></visual>
    <collision><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.010" length="0.22"/></geometry></collision>
    <inertial><origin xyz="0 0 0" rpy="0 0 0"/><mass value="0.10"/>
      <inertia ixx="0.000406" ixy="0.0" ixz="0.0" iyy="0.000406" iyz="0.0" izz="0.000005"/></inertial>
  </link>
  <joint name="standoff_rod_3_joint" type="fixed">
    <parent link="base_link"/><child link="standoff_rod_3"/>
    <origin xyz="-0.10 0.10 0.1875" rpy="0 0 0"/>
  </joint>

  <link name="standoff_rod_4">
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.010" length="0.22"/></geometry>
      <material name="metal_grey"/></visual>
    <collision><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.010" length="0.22"/></geometry></collision>
    <inertial><origin xyz="0 0 0" rpy="0 0 0"/><mass value="0.10"/>
      <inertia ixx="0.000406" ixy="0.0" ixz="0.0" iyy="0.000406" iyz="0.0" izz="0.000005"/></inertial>
  </link>
  <joint name="standoff_rod_4_joint" type="fixed">
    <parent link="base_link"/><child link="standoff_rod_4"/>
    <origin xyz="-0.10 -0.10 0.1875" rpy="0 0 0"/>
  </joint>

  <!-- ============================ CUP HOLDER TRAY ============================ -->
  <!-- VERIFIED from drawing: Ø320 (r=0.160), thickness 0.090 -->
  <!-- tray centre z = rod_top(0.2975) + tray_half(0.045) = 0.3425 -->
  <link name="cup_holder_tray">
    <visual><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.160" length="0.090"/></geometry>
      <material name="body_blue"/></visual>
    <collision><origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.160" length="0.090"/></geometry></collision>
    <inertial><origin xyz="0 0 0" rpy="0 0 0"/><mass value="0.5"/>
      <inertia ixx="0.003538" ixy="0.0" ixz="0.0" iyy="0.003538" iyz="0.0" izz="0.006400"/></inertial>
  </link>
  <joint name="cup_holder_tray_joint" type="fixed">
    <parent link="base_link"/><child link="cup_holder_tray"/>
    <origin xyz="0 0 0.3425" rpy="0 0 0"/>
  </joint>

  <!-- ============================ LASER SCANNER ============================ -->
  <!-- OFFSET, not centred: x = +0.08 (confirm exact value from drawing) -->
  <link name="laser_scan_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <!-- FLAG: set the real mesh filename from cp3_auxiliary_files (see README) -->
      <geometry><mesh filename="package://barista_robot_description/meshes/ouster_os1_32.dae"/></geometry>
      <material name="laser_black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.030" length="0.040"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.10"/>
      <inertia ixx="0.0000358" ixy="0.0" ixz="0.0"
               iyy="0.0000358" iyz="0.0" izz="0.000045"/>
    </inertial>
  </link>
  <joint name="laser_scan_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser_scan_link"/>
    <origin xyz="0.08 0 0.0775" rpy="0 0 0"/>
  </joint>

  <!-- ============================================================================
       GAZEBO (IGNITION FORTRESS) PLUGINS & SENSORS
       ============================================================================ -->

  <!-- Differential drive: subscribes /cmd_vel, publishes /odom + /tf(odom->base_link) -->
  <gazebo>
    <plugin filename="gz-sim-diff-drive-system"
            name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.3766</wheel_separation>   <!-- 2 * 0.1883 -->
      <wheel_radius>0.0352</wheel_radius>
      <odom_publish_frequency>30</odom_publish_frequency>
      <topic>cmd_vel</topic>
      <odom_topic>odom</odom_topic>
      <tf_topic>/tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
    </plugin>
  </gazebo>

  <!-- Laser scanner: gpu_lidar, publishes /scan, frame_id = laser_scan_link -->
  <gazebo reference="laser_scan_link">
    <sensor name="laser_scanner" type="gpu_lidar">
      <pose>0 0 0 0 0 0</pose>
      <topic>scan</topic>
      <update_rate>10</update_rate>
      <always_on>true</always_on>
      <visualize>true</visualize>
      <!-- Harmonic tag that sets the ROS header.frame_id on the bridged scan -->
      <gz_frame_id>laser_scan_link</gz_frame_id>
      <lidar>
        <scan>
          <horizontal>
            <samples>360</samples>
            <resolution>1</resolution>
            <min_angle>-3.141592</min_angle>
            <max_angle>3.141592</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.12</min>
          <max>10.0</max>
          <resolution>0.015</resolution>
        </range>
      </lidar>
    </sensor>
  </gazebo>

</robot>
